{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oduit.dev/schemas/agent/batch-addon-inspection.schema.json",
  "type": "object",
  "required": ["type", "data"],
  "properties": {
    "type": {
      "const": "batch_addon_inspection"
    },
    "data": {
      "type": "object",
      "required": ["modules", "inspections", "found_count", "missing_modules"],
      "properties": {
        "modules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "inspections": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "found_count": {
          "type": "integer"
        },
        "missing_modules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
