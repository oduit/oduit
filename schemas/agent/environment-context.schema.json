{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oduit.dev/schemas/agent/environment-context.schema.json",
  "type": "object",
  "required": ["type", "data"],
  "properties": {
    "type": {
      "const": "environment_context"
    },
    "data": {
      "type": "object",
      "required": [
        "environment",
        "addons_paths",
        "odoo",
        "database",
        "available_module_count"
      ],
      "properties": {
        "environment": {
          "type": "object"
        },
        "addons_paths": {
          "type": "object"
        },
        "odoo": {
          "type": "object"
        },
        "database": {
          "type": "object"
        },
        "available_module_count": {
          "type": "integer"
        },
        "duplicate_modules": {
          "type": "object"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
