{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oduit.dev/schemas/agent/addon-documentation.schema.json",
  "type": "object",
  "required": [
    "type",
    "module",
    "source_only",
    "dependency_graph",
    "models",
    "diagrams",
    "markdown"
  ],
  "properties": {
    "type": { "const": "addon_documentation" },
    "module": { "type": "string" },
    "database": { "type": "string" },
    "source_only": { "type": "boolean" },
    "addon_info": {
      "type": ["object", "null"]
    },
    "dependency_graph": {
      "type": "object"
    },
    "models": {
      "type": "array",
      "items": { "type": "object" }
    },
    "recommended_tests": {
      "type": "object"
    },
    "diagrams": {
      "type": "array",
      "items": { "type": "object" }
    },
    "sections": {
      "type": "array",
      "items": { "type": "object" }
    },
    "markdown": { "type": "string" }
  },
  "additionalProperties": true
}
