{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oduit.dev/schemas/agent/xmlid-inspection.schema.json",
  "type": "object",
  "required": ["type", "operation", "data"],
  "properties": {
    "type": {
      "const": "xmlid_inspection"
    },
    "operation": {
      "const": "inspect_ref"
    },
    "data": {
      "type": "object",
      "required": ["xmlid", "exists"],
      "properties": {
        "xmlid": {
          "type": "string"
        },
        "exists": {
          "type": "boolean"
        },
        "model": {
          "type": "string"
        },
        "res_id": {
          "type": "integer"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
