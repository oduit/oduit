{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oduit.dev/schemas/agent/field-inspection.schema.json",
  "type": "object",
  "required": ["type", "operation", "model", "field", "exists"],
  "properties": {
    "type": { "const": "field_inspection" },
