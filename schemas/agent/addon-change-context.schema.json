{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oduit.dev/schemas/agent/addon-change-context.schema.json",
  "type": "object",
  "required": ["type", "module", "steps", "recommended_next_steps"],
  "properties": {
    "type": { "const": "addon_change_context" },
    "module": { "type": "string" },
    "model": { "type": "string" },
    "field": { "type": "string" },
    "requested_attributes": { "type": "array", "items": { "type": "string" } },
    "requested_view_types": { "type": "array", "items": { "type": "string" } },
    "database": { "type": "string" },
    "timeout": { "type": "number" },
    "steps": { "type": "object" },
    "completed_steps": { "type": "array", "items": { "type": "string" } },
    "failed_step": { "type": "string" },
    "soft_failed_steps": { "type": "array", "items": { "type": "string" } },
    "recommended_next_steps": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
