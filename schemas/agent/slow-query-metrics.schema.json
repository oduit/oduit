{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oduit.dev/schemas/agent/slow-query-metrics.schema.json",
  "type": "object",
  "required": ["type", "operation", "data"],
  "properties": {
    "type": {
      "const": "slow_query_metrics"
    },
    "operation": {
      "const": "performance_slow_queries"
    },
    "data": {
      "type": "object",
      "required": ["queries", "limit"],
      "properties": {
        "queries": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "limit": {
          "type": "integer"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
