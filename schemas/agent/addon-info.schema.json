{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oduit.dev/schemas/agent/addon-info.schema.json",
  "type": "object",
  "required": [
    "type",
    "module",
    "module_path",
    "addon_type",
    "version_display",
    "depends",
    "models",
    "inherit_models",
    "test_cases",
    "languages",
    "installed_state"
  ],
  "properties": {
    "type": { "const": "addon_info" },
    "module": { "type": "string" },
    "module_path": { "type": "string" },
    "addon_type": { "type": "string" },
    "version_display": { "type": "string" },
    "summary": { "type": "string" },
    "description": { "type": "string" },
    "license": { "type": "string" },
    "depends": { "type": "array", "items": { "type": "string" } },
    "reverse_dependencies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "reverse_dependency_count": { "type": "integer" },
    "missing_dependencies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "installable": { "type": "boolean" },
    "auto_install": { "type": "boolean" },
    "models": { "type": "array", "items": { "type": "string" } },
    "inherit_models": {
      "type": "array",
      "items": { "type": "string" }
    },
    "model_count": { "type": "integer" },
    "test_cases": { "type": "array", "items": { "type": "object" } },
    "test_count": { "type": "integer" },
    "languages": { "type": "array", "items": { "type": "string" } },
    "installed_state": {
      "type": "object",
      "required": [
        "success",
        "operation",
        "module",
        "record_found",
        "state",
        "installed"
      ],
      "properties": {
        "success": { "type": "boolean" },
        "operation": { "type": "string" },
        "module": { "type": "string" },
        "record_found": { "type": "boolean" },
        "state": { "type": "string" },
        "installed": { "type": "boolean" },
        "database": { "type": "string" },
        "error": { "type": "string" },
        "error_type": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
