{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oduit.dev/schemas/agent/model-source-location.schema.json",
  "type": "object",
  "required": ["type", "data"],
  "properties": {
    "type": {
      "const": "model_source_location"
    },
    "data": {
      "type": "object",
      "required": [
        "model",
        "module",
        "addon_root",
        "resolution",
        "ambiguous",
        "candidates"
      ],
      "properties": {
        "model": {
          "type": "string"
        },
        "module": {
          "type": "string"
        },
        "addon_root": {
          "type": "string"
        },
        "resolution": {
          "type": "string"
        },
        "ambiguous": {
          "type": "boolean"
        },
        "ambiguity_reason": {
          "type": "string"
        },
        "candidates": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "path",
              "class_name",
              "match_kind",
              "declared_model",
              "confidence",
              "match_strength",
              "evidence"
            ],
            "properties": {
              "path": {
                "type": "string"
              },
              "class_name": {
                "type": "string"
              },
              "match_kind": {
                "type": "string"
              },
              "declared_model": {
                "type": "string"
              },
              "confidence": {
                "type": "number"
              },
              "match_strength": {
                "type": "string"
              },
              "evidence": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              },
              "line_hint": {
                "type": "integer"
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
