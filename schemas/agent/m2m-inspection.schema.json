{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oduit.dev/schemas/agent/m2m-inspection.schema.json",
  "type": "object",
  "required": ["type", "operation", "data"],
  "properties": {
    "type": {
      "const": "m2m_inspection"
    },
    "operation": {
      "const": "inspect_m2m"
    },
    "data": {
      "type": "object",
      "required": ["model", "field", "relation_table"],
      "properties": {
        "model": {
          "type": "string"
        },
        "field": {
          "type": "string"
        },
        "relation_table": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
