{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oduit.dev/schemas/agent/module-inspection.schema.json",
  "type": "object",
  "required": ["type", "operation", "data"],
  "properties": {
    "type": {
      "const": "module_inspection"
    },
    "operation": {
      "const": "inspect_modules"
    },
    "data": {
      "type": "object",
      "required": ["modules", "names", "total"],
      "properties": {
        "modules": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "names": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "total": {
          "type": "integer"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
