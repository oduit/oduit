{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oduit.dev/schemas/agent/subtype-inventory.schema.json",
  "type": "object",
  "required": ["type", "operation", "data"],
  "properties": {
    "type": {
      "const": "subtype_inventory"
    },
    "operation": {
      "const": "inspect_subtypes"
    },
    "data": {
      "type": "object",
      "required": ["model", "subtypes", "total"],
      "properties": {
        "model": {
          "type": "string"
        },
        "subtypes": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "total": {
          "type": "integer"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
